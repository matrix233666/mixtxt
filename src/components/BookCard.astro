---
import BookMeta from "./BookMeta.astro";

interface Props {
  book: {
    data: {
      slug: string;
      title: string;
      summary: string;
      status: "planning" | "serializing" | "completed" | "paused";
      updatedAt: string;
      original?: string;
      author?: string;
      adaptor?: string;
      startedAt?: string;
      copyrightStatus: "public-domain" | "authorized" | "private-draft" | "unknown";
      tags?: readonly string[];
    };
  };
}

const { book } = Astro.props;
---

<article
  class="book-card"
  data-book-card
  data-book-slug={book.data.slug}
  data-book-status={book.data.status}
  data-book-updated-at={book.data.updatedAt}
  data-book-title={book.data.title.toLowerCase()}
  data-book-tags={JSON.stringify(book.data.tags ?? [])}
>
  <a class="book-card__link" href={`/books/${book.data.slug}/`}>
    <div class="book-card__header">
      <h2>{book.data.title}</h2>
      <time datetime={book.data.updatedAt}>{book.data.updatedAt}</time>
    </div>
    <p>{book.data.summary}</p>
    <BookMeta book={book} variant="grid" />
  </a>
</article>
