---
import { buildReaderPreferenceBootstrapScript } from "../lib/reader-client";
import { getSiteConfig } from "../lib/site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const site = getSiteConfig();
const { title = site.title, description = site.description } = Astro.props;
const readerPreferenceBootstrapScript = buildReaderPreferenceBootstrapScript();
---

<!doctype html>
<html lang={site.defaultLanguage}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline set:html={readerPreferenceBootstrapScript}></script>
  </head>
  <body>
    <slot />
  </body>
</html>
