---
import { render } from "astro:content";
import ChapterList from "../../../components/ChapterList.astro";
import ChapterNav from "../../../components/ChapterNav.astro";
import ReaderToolbar from "../../../components/ReaderToolbar.astro";
import ReaderLayout from "../../../layouts/ReaderLayout.astro";
import {
  getBookBySlug,
  getChapterNav,
  getPublicBooks,
  getPublishedChapters
} from "../../../lib/content";
import { defaultReaderPreferences } from "../../../lib/reading";

export async function getStaticPaths() {
  const books = await getPublicBooks();
  const paths = await Promise.all(
    books.map(async (book) => {
      const chapters = await getPublishedChapters(book.data.slug);
      return chapters.map((chapter) => ({
        params: {
          book: book.data.slug,
          chapter: chapter.data.slug
        }
      }));
    })
  );

  return paths.flat();
}

const { book, chapter } = Astro.params;
const nav = await getChapterNav(book!, chapter!);
const bookEntry = await getBookBySlug(book!);
const currentChapter = nav.current!;
const { Content } = await render(currentChapter);
const directoryId = `reader-directory-${book}`;
---

<ReaderLayout
  title={`${currentChapter.data.title} | ${bookEntry?.data.title ?? currentChapter.data.book}`}
  description={currentChapter.data.summary}
>
  <article
    class="reader-page"
    data-reader-root
    data-reader-theme={defaultReaderPreferences.theme}
    data-reader-font-size={defaultReaderPreferences.fontSize}
    data-reader-line-height={defaultReaderPreferences.lineHeight}
    data-reader-width={defaultReaderPreferences.width}
  >
    <header class="reader-header card-surface">
      <a class="reader-header__back" href={`/books/${book}/`}>
        返回《{bookEntry?.data.title ?? currentChapter.data.book}》
      </a>
      <p class="eyebrow">第 {currentChapter.data.chapterNo} 章</p>
      <h1>{currentChapter.data.title}</h1>
      <p>{currentChapter.data.summary}</p>
      <div class="reader-meta">
        <span>
          更新于 <time datetime={currentChapter.data.updatedAt}>{currentChapter.data.updatedAt}</time>
        </span>
        {typeof currentChapter.data.wordCount === "number" && (
          <span>{currentChapter.data.wordCount.toLocaleString("zh-CN")} 字</span>
        )}
      </div>
    </header>

    <ReaderToolbar
      bookSlug={book!}
      chapterSlug={chapter!}
      chapterTitle={currentChapter.data.title}
      directoryId={directoryId}
    />

    <details class="reader-directory card-surface" id={directoryId} open>
      <summary>章节目录</summary>
      <ChapterList chapters={nav.chapters} activeChapterSlug={currentChapter.data.slug} />
    </details>

    <section class="reader-content card-surface">
      <div class="reader-body" data-pagefind-body>
        <Content />
      </div>
    </section>

    <ChapterNav prev={nav.prev} next={nav.next} bookSlug={book!} />
  </article>
</ReaderLayout>
